# Local knowledge-base repository path
KNOWLEDGE_BASE_DIR=../knowledge-base

# Agent backend mode: mock, pi, or my-agent-loop
AGENT_MODE=mock

# Pi SDK integration
PI_NODE_COMMAND=node
PI_TIMEOUT_SECONDS=180
# PI_WORKDIR=../knowledge-base
# Install the SDK in gogo-app with: npm install

# Local my-agent-loop integration
MY_AGENT_LOOP_DIR=../my-agent-loop
# MY_AGENT_LOOP_MODEL=grok-4-fast

# Optional model provider keys
# BUILDER_API_KEY=your-key
# DASHSCOPE_API_KEY=your-key
# OPENAI_API_KEY=your-key
# ANTHROPIC_API_KEY=your-key
